# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://pixelvault:pixelvault@localhost:5432/pixelvault

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# S3 (s3rver for local dev)
S3_ENDPOINT=http://localhost:4569
S3_BUCKET=pixelvault-media
S3_ACCESS_KEY=S3RVER
S3_SECRET_KEY=S3RVER-PASSWORD
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Signed URL expiry in seconds (15 minutes)
SIGNED_URL_EXPIRY=900

# Rate limiting
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_UNLOCK_WINDOW_MS=900000
RATE_LIMIT_UNLOCK_MAX=20
